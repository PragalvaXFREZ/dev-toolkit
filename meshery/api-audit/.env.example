# Google Sheets credentials — use ONE of the following:

# Option 1: Inline JSON (recommended for CI / GitHub Actions secrets)
# GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"..."}'

# Option 2: Path to a service account key file (for local development)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# Google Sheet ID (the long string in the sheet URL)
SHEET_ID=your_google_sheet_id

# Path to meshery/meshery repo
MESHERY_REPO_PATH=/path/to/meshery

# Note: the script currently writes to worksheet index 4 in the spreadsheet.
